doctype html
html
    head
        title= title
        meta(name="viewport" content="width=device-width, initial-scale=1")
        link(rel="stylesheet", href="/css/style.css")
    body
        h1 Houseplants
        a(href="/update-cobj") Add to this table
        table
            thead
                tr
                    th Name
                    th Species
                    th Light Level
            tbody
                each plant in data
                    tr
                        td #{plant.properties.name}
                        td #{plant.properties.species}
                        td #{plant.properties.light_level}
